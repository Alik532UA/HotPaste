{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:path:default",
    "core:path:allow-join",
    "core:path:allow-resolve-directory",
    "fs:default",
    "autostart:default",
    "log:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "schemes": [
            "https",
            "http",
            "mailto",
            "tel",
            "file"
          ]
        },
        {
          "regex": "^(https?|file|mailto|tel|ms-settings):.+"
        },
        {
          "regex": "^[a-zA-Z]:\\\\.+"
        },
        {
          "regex": "^/.+"
        }
      ]
    },
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$DOCUMENT/HotPaste"
        },
        {
          "path": "$DOCUMENT/HotPaste/**"
        },
        {
          "path": "$DOCUMENT/HotPaste/default-project"
        },
        {
          "path": "$DOCUMENT/HotPaste/default-project/**"
        },
        {
          "path": "$DOCUMENT/HotPaste/start"
        },
        {
          "path": "$DOCUMENT/HotPaste/start/**"
        }
      ]
    },
    "process:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "explorer",
          "cmd": "explorer",
          "args": [
            {
              "validator": ".+"
            }
          ]
        }
      ]
    }
  ]
}