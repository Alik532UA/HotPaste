{
  "name": "hotpaste",
  "private": true,
  "version": "0.1.37",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "if (Test-Path dist) { Remove-Item -Recurse -Force dist }; if (Test-Path src-tauri/target) { Remove-Item -Recurse -Force src-tauri/target }",
    "version:bump": "node scripts/bump-version.js",
    "build": "vite build",
    "tauri:build": "npm run build && tauri build --bin HotPaste",
    "build:full": "powershell -Command \"npm run clean; npm run build; tauri build --bin HotPaste\"",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "husky": "^8.0.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "dompurify": "^3.3.2",
    "fuse.js": "^7.1.0",
    "lucide-svelte": "^0.577.0",
    "snarkdown": "^2.0.0",
    "zod": "^4.3.6"
  }
}
